{
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "es2020",
        "esModuleInterop": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "types": ["jest", "node"],
        "isolatedModules": true,
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules", "dist", "src/__tests__"],
    "references": [
        { "path": "./tsconfig.test.json" }
    ]
}